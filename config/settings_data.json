      "feature_row_hxxftX": {
        "type": "feature-row",
        "name": "Image with text",
        "settings": {
          "image": "shopify://shop_images/TOAST_HannahWatts_291_1.jpg",
          "layout": "right",
          "full_width": true,
          "color_scheme": "4",
          "title": "Upcoming Exhibtions",
          "text": "<p><em>28th July - 28th August 2025 </em></p><ul><li><em>'Summer Exhibition</em>' at The Gallery at Green and Stone </li></ul><p></p><p><strong>You can also find my work here...</strong></p><p><a href=\"https://www.toa.st/collections/hannah-watts-ceramics\" target=\"_blank\" title=\"TOAST\">TOAST</a></p><p><a href=\"https://www.wsjgallery.com/artists/340-hannah-watts/works/\" target=\"_blank\" title=\"WSJ Gallery\">WSJ Gallery</a></p><p><a href=\"https://chandlerhouse.co.za/exhibtion/hannah-watts/\" target=\"_blank\" title=\"Chandler House\">Chandler House (Cape Town)</a></p><p><a href=\"https://mah-gallery.com/hannah-watts\" target=\"_blank\">M.A.H Gallery</a></p><p><a href=\"https://www.wonderingpeople.com/pages/home-collection\" target=\"_blank\" title=\"WONDERING PEOPLE\">Wondering People</a></p><p><a href=\"https://www.felt-collections.com/shop/plates\" target=\"_blank\" title=\"Felt\">FELT</a></p><p><a href=\"https://birdiefortescue.co.uk/collections/hannah-watts\" target=\"_blank\">Birdie Fortescue</a></p><p></p>",
          "button_label": "",
          "button_link": ""
        }
      },
      "columns_rB8zcJ": {
        "type": "columns",
        "blocks": {
          "column_mx99D6": {
            "type": "column",
            "settings": {
              "alignment": "left"
            }
          },
          "heading_bipdFi": {
            "type": "heading",
            "settings": {
              "heading": "Silo Studio holds Hannah's artwork alongside the homewares she designs. It is where she experiments, moves between mediums, and works with other artists.",
              "heading_size": "medium",
              "heading_tag": "h3"
            }
          },
          "column_b3WQde": {
            "type": "column",
            "settings": {
              "alignment": "left"
            }
          },
          "text_KHFj4i": {
            "type": "text",
            "settings": {
              "text": "<p>Her reference points are largely tropical: the African landscape, its architecture and its craft, and above all its textiles. She builds dreamworlds into her designs, exaggerating the natural elements around us, the plants and flowers in particular, with pattern running through everything.</p><p></p>"
            }
          },
          "text_ah47A8": {
            "type": "text",
            "settings": {
              "text": "<p>Every piece is made by hand, either by Hannah herself or by the specialist artisans she works with.</p>"
            }
          }
        },
